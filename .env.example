APP_NAME=yourapp
APP_ENV=development

HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_SHUTDOWN_TIMEOUT=5s

LOG_LEVEL=info

SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_LEVEL=info

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

DB_MYSQL_WRITE_DSN="user:pass@tcp(localhost:3306)/yourapp_write?parseTime=true"
DB_MYSQL_WRITE_MAX_OPEN_CONNS=50
DB_MYSQL_WRITE_MAX_IDLE_CONNS=10
DB_MYSQL_WRITE_CONN_MAX_LIFETIME=30m
DB_MYSQL_WRITE_CONN_MAX_IDLE_TIME=15m

DB_MYSQL_READ_DSN="user:pass@tcp(localhost:3306)/yourapp_read?parseTime=true"
DB_MYSQL_READ_MAX_OPEN_CONNS=100
DB_MYSQL_READ_MAX_IDLE_CONNS=20
DB_MYSQL_READ_CONN_MAX_LIFETIME=30m
DB_MYSQL_READ_CONN_MAX_IDLE_TIME=15m

JWT_ACCESS_SECRET="ganti-dengan-rahasia-akses-super-panjang"
JWT_REFRESH_SECRET="ganti-dengan-rahasia-penyegar-super-panjang"
JWT_ISSUER="yourapp-api"
JWT_AUDIENCE="yourapp-client"
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h
